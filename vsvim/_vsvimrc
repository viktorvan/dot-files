set backspace=indent,eol,start
set clipboard=unnamed

" Map leader to space
let mapleader=' '

" Search settings
set hlsearch
set incsearch
set ignorecase
set smartcase

" Search mappings: These will make it so that going to the next one in a
" search will center on the line it's found in.
nnoremap n nzzzv
nnoremap N Nzzzv

" Some useful remappings
cnoreabbrev W! w!
cnoreabbrev Q! q!
cnoreabbrev Qall! qall!
cnoreabbrev Wq wq
cnoreabbrev Wa wa
cnoreabbrev wQ wq
cnoreabbrev WQ wq
cnoreabbrev W w
cnoreabbrev Q q
cnoreabbrev Qall qall

" Splits
noremap <Leader>h :<C-u>split<CR>
noremap <Leader>v :<C-u>vsplit<CR>

" Easier search
nmap <leader>f /

" Easier escape
map! hh <ESC>
vmap hh <ESC>
omap hh <ESC>
cmap hh <C-c>

" Clean search (highlight)
nnoremap <leader><space> :noh<cr>

" Tab navigation
nnoremap <Leader>w gt
nnoremap <Leader>q gT

" Visual studio
nnoremap gd :vsc ReSharper.ReSharper_GotoDeclaration<CR>
nnoremap gi :vsc Resharper.ReSharper_GotoImplementations<CR>
nnoremap <Leader>r :vsc Debug.Start<CR>
nnoremap <Leader>b :vsc Build.BuildSolution<CR>
vmap v :vsc ReSharper.ReSharper_ExtendSelection<CR>
vmap <C-V> :vsc ReSharper.ReSharper_ShrinkSelection<CR>
nmap <C-o> :vsc View.NavigateBackward<CR>
nmap <C-i> :vsc View.NavigateForward<CR>
nnoremap <Leader>l :so c:\Users\vikand02\_vsvimrc<CR>
map <Leader>t :vsc ReSharper.ReSharper_GotoType<CR>
inoremap <Leader>t :vsc ReSharper.ReSharper_GotoType<CR>
map gcc :vsc Edit.CommentSelection<CR>
map gcgc :vsc Edit.UnCommentSelection<CR>

" copied from Vim 7.3's mswin.vim:

" CTRL-X and SHIFT-Del are Cut
vnoremap <C-X> "+x
vnoremap <S-Del> "+x

" CTRL-C and CTRL-Insert are Copy
vnoremap <C-C> "+y
vnoremap <C-Insert> "+y

" CTRL-V and SHIFT-Insert are Paste
map <C-V>       "+gP
map <S-Insert>      "+gP
imap <C-V>      <Esc>"+gpa

cmap <C-V>      <C-R>+
cmap <S-Insert>     <C-R>+


imap <S-Insert>     <C-V>
vmap <S-Insert>     <C-V>

" Use CTRL-Q to do what CTRL-V used to do
noremap <C-Q>       <C-V>
